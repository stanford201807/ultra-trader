# ========================================
# UltraTrader 環境變數設定
# 複製此檔案為 .env，填入你的資訊
# ========================================

# 永豐 Shioaji API 金鑰
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=

# 憑證（實單交易才需要）
SHIOAJI_CA_PATH=
SHIOAJI_CA_PASSWORD=
SHIOAJI_PERSON_ID=

# 交易模式：simulation（本地模擬）| paper（永豐模擬盤）| live（實單）
TRADING_MODE=simulation

# 交易商品
CONTRACT_CODE=MXF

# 風險等級：conservative | balanced | aggressive
RISK_PROFILE=balanced

# Dashboard 設定
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8888
